---
import Layout from '../layouts/Layout.astro';
import { name, experience, education } from '../data';
---

<Layout title={`Experience | ${name}`}>
	<main>
		<nav>
			<a href="/" class="back-link">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
				Back
			</a>
		</nav>

		<header>
			<h1 class="page-title">Experience</h1>
		</header>

		<section class="details-section">
			<div class="grid">
				{experience.map((exp) => (
					<div class="detail-card">
						<div class="detail-header">
							<h3>{exp.company}</h3>
							<span class="period">{exp.period}</span>
						</div>
						<p class="role">{exp.role}</p>
						<p class="desc">{exp.description}</p>
					</div>
				))}
			</div>
		</section>

		<header>
			<h1 class="page-title">Education</h1>
		</header>

		<section class="details-section">
			<div class="grid">
				{education.map((edu) => (
					<div class="detail-card">
						<div class="detail-header">
							<h3>{edu.institution}</h3>
							<span class="period">{edu.period}</span>
						</div>
						<p class="role">{edu.degree}</p>
						<p class="desc">{edu.details}</p>
						{edu.thesis && (
							<a href={edu.thesis} target="_blank" rel="noopener noreferrer" class="thesis-link">
								View Thesis
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
							</a>
						)}
					</div>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}

	nav {
		margin-bottom: 3rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: #64748b;
		font-weight: 500;
		transition: color 0.2s ease;
	}

	.back-link:hover {
		color: var(--accent-color);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: 2.5rem;
		margin-bottom: 2.5rem;
		color: var(--text-color);
	}

	.details-section {
		margin-bottom: 4rem;
	}

	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	.detail-card {
		background: white;
		border: 1px solid var(--border-color);
		border-radius: 1.5rem;
		padding: 2rem;
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
	}

	.detail-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 0.5rem;
	}

	.detail-header h3 {
		font-size: 1.25rem;
		font-weight: 600;
	}

	.period {
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--accent-color);
		background: var(--accent-light);
		padding: 0.25rem 0.75rem;
		border-radius: 2rem;
	}

	.role {
		font-weight: 500;
		color: #64748b;
		margin-bottom: 1rem;
	}

	.desc {
		color: #475569;
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	.thesis-link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--accent-color);
		transition: transform 0.2s ease;
	}

	.thesis-link:hover {
		transform: translateX(2px);
	}

	@media (max-width: 640px) {
		.detail-header {
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>
