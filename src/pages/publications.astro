---
import Layout from '../layouts/Layout.astro';
import { name, publications } from '../data';
---

<Layout title={`Publications | ${name}`}>
	<main>
		<nav>
			<a href="/" class="back-link">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
				Back
			</a>
		</nav>

		<header>
			<h1 class="page-title">Publications</h1>
		</header>

		<section class="details-section">
			<div class="grid">
				{publications.map((pub) => (
					<div class="detail-card">
						<div class="detail-header">
							<h3>{pub.title}</h3>
							<span class="venue">{pub.venue}</span>
						</div>
						<p class="desc">{pub.description}</p>
						<div class="links-container">
							{pub.arxiv && pub.arxiv !== "" && (
								<a href={pub.arxiv} target="_blank" rel="noopener noreferrer" class="pub-link arxiv">
									arXiv
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
								</a>
							)}
							{pub.official && pub.official !== "" && (
								<a href={pub.official} target="_blank" rel="noopener noreferrer" class="pub-link official">
									Official
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
								</a>
							)}
						</div>
					</div>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}

	nav {
		margin-bottom: 3rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: #64748b;
		font-weight: 500;
		transition: color 0.2s ease;
	}

	.back-link:hover {
		color: var(--accent-color);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: 2.5rem;
		margin-bottom: 2.5rem;
		color: var(--text-color);
	}

	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	.detail-card {
		background: white;
		border: 1px solid var(--border-color);
		border-radius: 1.5rem;
		padding: 2rem;
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
	}

	.detail-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1rem;
		gap: 1.5rem;
	}

	.detail-header h3 {
		font-size: 1.25rem;
		font-weight: 600;
		line-height: 1.4;
	}

	.venue {
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--accent-color);
		background: var(--accent-light);
		padding: 0.25rem 0.75rem;
		border-radius: 2rem;
		white-space: nowrap;
	}

	.desc {
		color: #475569;
		line-height: 1.6;
		margin-bottom: 1.5rem;
	}

	.links-container {
		display: flex;
		gap: 1rem;
	}

	.pub-link {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.875rem;
		font-weight: 600;
		padding: 0.5rem 1rem;
		border-radius: 0.75rem;
		transition: all 0.2s ease;
	}

	.pub-link.arxiv {
		background: #f1f5f9;
		color: #475569;
		border: 1px solid #e2e8f0;
	}

	.pub-link.official {
		background: var(--accent-light);
		color: var(--accent-color);
		border: 1px solid rgba(37, 99, 235, 0.2);
	}

	.pub-link:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
	}

	@media (max-width: 640px) {
		.detail-header {
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>
